# AlphaCouncil AI - 环境变量配置
# 复制此文件为 .env 并填入你自己的 API Key

# ============ AI 模型 API 配置 ============

# Google Gemini API (必需)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini API 代理地址 (可选, 中国大陆用户需要)
# 可部署 gemini_proxy_worker.js 到 Cloudflare Workers
# GEMINI_BASE_URL=https://your-proxy.workers.dev

# 支持多个 Gemini API Key 轮询 (可选)
# GEMINI_API_KEY_2=your_second_key
# GEMINI_API_KEY_3=your_third_key

# DeepSeek API (必需)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 API (必需)
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here

# OpenAI API (用于总经理 GPT-5.2 Pro, 通过 OpenRouter)
# 获取地址: https://openrouter.ai/keys
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ============ 数据源配置 ============

# 聚合数据 API (必需, 获取 A 股实时行情)
# 获取地址: https://www.juhe.cn/
# 需要申请: 沪深股票-基本数据接口
JUHE_API_KEY=your_juhe_api_key_here

# ============ 服务器配置 ============

PORT=3001

# ============ 支付宝支付配置 (可选) ============
# 如不需要付费功能可忽略以下配置
# 获取地址: https://open.alipay.com/

# 支付宝应用 ID
# ALIPAY_APP_ID=your_alipay_app_id

# 应用私钥 (RSA2)
# ALIPAY_PRIVATE_KEY=your_alipay_private_key

# 支付宝网关
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 支付宝证书路径 (相对于项目根目录)
# ALIPAY_APP_CERT_PATH=./certs/appCertPublicKey.crt
# ALIPAY_ALIPAY_CERT_PATH=./certs/alipayCertPublicKey_RSA2.crt
# ALIPAY_ROOT_CERT_PATH=./certs/alipayRootCert.crt

# 支付宝异步回调地址 (需公网可访问)
# ALIPAY_NOTIFY_URL=https://your-domain.com/AlphaCouncil/api/pay/alipay/notify

# 网站基础 URL (用于支付成功后跳转)
# BASE_URL=https://your-domain.com
